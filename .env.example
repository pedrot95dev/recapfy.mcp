# Base URL of the Recapfy API (no trailing slash). The MCP server calls
# `${RECAPFY_API_BASE_URL}/api/v1/agents/ask`.
# Local dev example:   https://localhost:7001
# Deployed example:    https://api.recapfy.ai
RECAPFY_API_BASE_URL=https://api.recapfy.ai

# Your Solana wallet secret key, base58-encoded (the 64-byte secret key, i.e.
# the format `solana-keygen` / Phantom "export private key" produce).
# This wallet pays 0.01 USDC per call. Keep it funded with USDC on the network
# the API advertises (mainnet by default). NEVER commit the real value.
SVM_PRIVATE_KEY=

# Optional. Allow self-signed TLS certs when pointing at local dev over https.
# Set to "1" only for localhost. Leave unset in production.
# RECAPFY_ALLOW_INSECURE_TLS=1
