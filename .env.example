# Your Solana wallet secret key, base58-encoded (the 64-byte secret key, i.e.
# the format `solana-keygen` / Phantom "export private key" produce).
# This wallet pays per call (dynamic USDC price). Keep it funded with USDC on the
# network the API advertises (mainnet by default). NEVER commit the real value.
SVM_PRIVATE_KEY=

# Optional. Override the API base URL (no trailing slash). Defaults to the
# production API at https://api.recapfy.ai; only set this for local API dev,
# e.g. https://localhost:7001
# RECAPFY_API_BASE_URL=https://localhost:7001

# Optional. Allow self-signed TLS certs when pointing at local dev over https.
# Set to "1" only for localhost. Leave unset in production.
# RECAPFY_ALLOW_INSECURE_TLS=1
