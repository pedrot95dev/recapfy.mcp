{
  "name": "recapfy-mcp",
  "version": "0.1.4",
  "description": "MCP server that exposes the Recapfy x402 \"ask\" endpoint as a tool. Each user runs it locally with their own Solana wallet and pays per call.",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pedrot95dev/recapfy.mcp.git"
  },
  "homepage": "https://github.com/pedrot95dev/recapfy.mcp#readme",
  "bugs": "https://github.com/pedrot95dev/recapfy.mcp/issues",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "x402",
    "solana",
    "youtube",
    "recapfy"
  ],
  "bin": {
    "recapfy-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    ".env.example"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@scure/base": "^2.2.0",
    "@solana/kit": "^6.10.0",
    "@x402/core": "^2.16.0",
    "@x402/fetch": "^2.16.0",
    "@x402/svm": "^2.16.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
  }
}
